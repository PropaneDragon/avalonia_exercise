<Window
x:Class="AvaloniaExercise.Views.MainWindow"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:icons="https://github.com/projektanker/icons.avalonia"
xmlns:local="using:AvaloniaExercise"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:vm="using:AvaloniaExercise.ViewModels"
Title="Animals Crossing"
d:DesignHeight="450"
d:DesignWidth="800"
x:DataType="vm:MainWindowViewModel"
Icon="/Assets/icon.ico"
RequestedThemeVariant="Dark"
Background="{DynamicResource SystemControlBackgroundListLowBrush}"
mc:Ignorable="d">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition
			Height="Auto" />
			<RowDefinition
			Height="*" />
		</Grid.RowDefinitions>
		<Border
		Grid.Row="0">
			<local:TrafficLightStatusView
			DataContext="{Binding TrafficLightStatusViewModel, Mode=OneTime}"
			/>
		</Border>
	</Grid>

</Window>
