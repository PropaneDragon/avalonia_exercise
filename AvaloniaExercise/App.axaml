<Application
    x:Class="AvaloniaExercise.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sty="using:FluentAvalonia.Styling"
    xmlns:local="using:AvaloniaExercise"
    RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <sty:FluentAvaloniaTheme CustomAccentColor="#EF4723" />
        <StyleInclude
            Source="/Style.axaml" />
    </Application.Styles>
</Application>